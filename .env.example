# =============================================================================
# WanderSort — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All POSTGRES_* variables are REQUIRED. Others have sensible defaults.
# =============================================================================

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080                          # HTTP listen port (default: 8080)
HOST=localhost:8080                # Host header for Swagger docs

# ── PostgreSQL (required) ───────────────────────────────────────────────────
POSTGRES_USER=wandersort
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wandersort

# ── Output ──────────────────────────────────────────────────────────────────
OUTPUT_PATH=                       # Where organized files go (default: ~/WanderSort_Library)

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info                     # debug | info | warn | error
LOG_FILE=                          # Path to JSON log file; empty = disabled

# ── Concurrency ─────────────────────────────────────────────────────────────
MAX_CONCURRENT_SCANS=5             # River scan queue workers
MAX_CONCURRENT_HASHERS=4           # River hash queue workers

# ── OpenTelemetry (optional) ────────────────────────────────────────────────
OTEL_ENABLED=false                 # Set to "true" to enable OTel export
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=wandersort
OTEL_SERVICE_VERSION=dev
export OTEL_SERVICE_NAME=wandersort
